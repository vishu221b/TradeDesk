# Frontend build/runtime config.

# Where the API lives. In dev, leave unset — Vite proxies "/api" to the backend
# (see vite.config.ts). In production behind nginx, "/api" is proxied too, so
# this can stay "/api". Set an absolute URL only if the API is on another origin.
# VITE_API_BASE=/api

# Dev-only: where the Vite proxy forwards "/api" requests.
# VITE_PROXY_TARGET=http://localhost:8000
