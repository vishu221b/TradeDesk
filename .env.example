# Copy to .env. Every value here is optional for local/demo use — the app boots
# on the built-in keyless `mock` provider with an auto-created SQLite database.
# Set the starred (*) values before deploying to production.

# --- Security (* set in production) ---------------------------------------
# JWT signing key.   generate: openssl rand -hex 32
TRADEDESK_SECRET_KEY=
# Encrypts per-user provider keys at rest.
#   generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
TRADEDESK_FERNET_KEY=
# How long a login token lasts (minutes). Default 7 days.
# TRADEDESK_TOKEN_TTL_MINUTES=10080

# --- Database -------------------------------------------------------------
# Default: a SQLite file under data/. Point at Postgres in production, e.g.
#   postgresql+psycopg://user:pass@host:5432/tradedesk
# TRADEDESK_DATABASE_URL=sqlite:///./data/tradedesk.db

# --- Provider API keys (server-side defaults; users can also add their own) -
# Anthropic (Claude):  https://console.anthropic.com/
ANTHROPIC_API_KEY=
# OpenAI (ChatGPT):    https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Google (Gemini):     https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Ollama (local models): run `ollama serve`; a key is usually NOT required.
OLLAMA_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434/v1
